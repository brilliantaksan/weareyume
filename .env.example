# Supabase — from your project's API settings (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. Used by the seed script. NEVER expose to the browser / commit.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# The single email allowed into /admin (Google sign-in must match this)
NEXT_PUBLIC_ADMIN_EMAIL=hello@weareyume.com

# Public site origin (used for OAuth redirect). In prod: https://weareyume.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
